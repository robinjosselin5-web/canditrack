{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "skipLibCheck": true,
    "strict": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noFallthroughCasesInSwitch": true,
    "rootDir": "src/server",
    "outDir": "dist/server",
    "declaration": true,
    "sourceMap": true
  },
  "include": ["src/server/**/*.ts"]
}
